# =============================================
# LLM Migration Factory — Environment Variables
# =============================================
# Set this to "true" to run the entire pipeline without 
# consuming API credits or requiring valid API keys!
USE_MOCK_APIS=true

# --- Source Model (The original code being migrated) ---
SOURCE_MODEL=gpt-3.5-turbo
SOURCE_BASE_URL=https://api.openai.com/v1
SOURCE_API_KEY=your_source_api_key_here

# --- Target Model (Where you want to migrate to) ---
# E.g. NVIDIA NIM, Together AI, Groq, local vLLM, etc.
TARGET_PROVIDER="NVIDIA Llama"
TARGET_MODEL=meta/llama-3.3-70b-instruct
TARGET_BASE_URL=https://integrate.api.nvidia.com/v1

# The API KEY used by the Factory to test the model
TARGET_API_KEY=your_target_api_key_here

# The exact Environment Variable NAME that your refactored code will look for
# (e.g., if you set this to "TOGETHER_API_KEY", your generated script will have:
#  `api_key=os.environ.get("TOGETHER_API_KEY")`)
TARGET_API_KEY_ENV_VAR=NVIDIA_API_KEY

# --- Judge Model (Evaluates semantic fidelity) ---
JUDGE_MODEL=gemini-2.0-flash
JUDGE_API_KEY=your_judge_api_key_here

# --- Optimizer Model (Prompt Translator) ---
OPTIMIZER_MODEL=llama3-70b-8192
OPTIMIZER_API_KEY=your_optimizer_api_key_here

# --- Engine Rules ---
OPTIMIZATION_THRESHOLD=90
OPTIMIZATION_MAX_ITERATIONS=5
