# =============================================
# LLM Migration Factory — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys.
# Keys are NEVER collected via the frontend UI.

# --- Source Model (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- Target Model (NVIDIA NIM / Llama) ---
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Judge Model (Gemini) ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# --- Optimizer / Prompt Rewriter (Groq Llama) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# --- Optimizer Settings ---
OPTIMIZATION_THRESHOLD=90
OPTIMIZATION_MAX_ITERATIONS=5
