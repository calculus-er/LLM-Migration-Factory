# =============================================
# LLM Migration Factory — Environment Variables
# =============================================
# Set this to "true" to run the entire pipeline without 
# consuming API credits or requiring valid API keys!
USE_MOCK_APIS=true

# --- Source Model (The code being migrated FROM) ---
# This is the model your uploaded script targets. The Factory calls it to
# capture the "golden truth" baseline response.
SOURCE_MODEL=openai/gpt-oss-20b
SOURCE_BASE_URL=https://api.groq.com/openai/v1
SOURCE_API_KEY=your_groq_api_key_here

# --- Target Model (The code being migrated TO) ---
# The Factory rewrites your code to call this model instead.
TARGET_PROVIDER="Groq Llama"
TARGET_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
TARGET_BASE_URL=https://api.groq.com/openai/v1
TARGET_API_KEY=your_groq_api_key_here

# The env var name injected into the final refactored Python script
# (e.g., the downloaded script will contain: api_key=os.environ.get("GROQ_API_KEY"))
TARGET_API_KEY_ENV_VAR=GROQ_API_KEY

# --- Judge Model (Evaluates semantic fidelity) ---
# Compares the target model's output against the golden truth and scores it.
JUDGE_MODEL=openai/gpt-oss-120b
JUDGE_BASE_URL=https://api.groq.com/openai/v1
JUDGE_API_KEY=your_groq_api_key_here

# --- Optimizer Model (Prompt Translator) ---
# Rewrites prompts from the source format to be optimized for the target model.
OPTIMIZER_MODEL=llama-3.3-70b-versatile
OPTIMIZER_BASE_URL=https://api.groq.com/openai/v1
OPTIMIZER_API_KEY=your_groq_api_key_here

# --- Engine Rules ---
OPTIMIZATION_THRESHOLD=90
OPTIMIZATION_MAX_ITERATIONS=5
